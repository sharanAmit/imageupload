# Trip Memories Platform Configuration

# Database Configuration
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trip_memories

# JWT Authentication
# Generate strong random keys for production (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=supersecretkeychangeinproduction1234567890
JWT_REFRESH_SECRET_KEY=supersecretrefreshkeychangeinproduction1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload Directory (will be created in project root if relative)
# For absolute Windows path: C:\path\to\uploads
# Or use relative path like 'uploads'
UPLOAD_DIR=uploads
